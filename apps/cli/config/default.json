{
  "cacheDir": "keyb/firmware",
  "draw": {
    "outputDir": "keymap-drawer",
    "config": "keymap-drawer/config.yaml"
  },
  "github": {
    "owner": "3dyuval",
    "repo": "keyboards-firmware"
  },
  "logging": {
    "flash": ["create"],
    "firmware": ["create", "get"],
    "draw": ["create", "get"],
    "parse": ["create"],
    "status": ["find", "get"]
  },
  "keyboards": {
    "iris": {
      "workflow": "build-qmk.yml",
      "artifact": "Firmware",
      "type": "qmk",
      "keymap": "keyboards/keebio/iris_lm/k1/keymaps/graphite/keymap.c"
    },
    "corne": {
      "workflow": "build-zmk.yml",
      "artifact": "firmware",
      "type": "zmk"
    },
    "eyelash": {
      "workflow": "build-zmk.yml",
      "artifact": "firmware",
      "type": "zmk",
      "keymap": "config/eyelash_corne.keymap"
    },
    "totem": {
      "workflow": "build-zmk.yml",
      "artifact": "firmware",
      "type": "zmk"
    }
  }
}
